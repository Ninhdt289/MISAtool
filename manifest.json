{
  "manifest_version": 3,
  "name": "MISA Calendar Integration",
  "version": "1.0",
  "description": "Chrome Extension to integrate MISA AMIS Tuyển dụng with Google Calendar for booking interview schedules.",
  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://*.misa.vn/*",
    "https://www.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.misa.vn/*"],
      "js": ["config.js", "content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "MISA Calendar"
  },
  "oauth2": {
    "client_id": "429950432093-tcd5pbva31e1lgk27udj9n78ghah3f7o.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.events",
      "https://www.googleapis.com/auth/calendar.freebusy"
    ]
  }
}